# Base de données Neon (PostgreSQL) — NE JAMAIS committer les vraies valeurs.
# Copiez ce fichier en .env et remplissez avec vos chaînes de connexion Neon.

# Connexion applicative : idéalement l'URL « poolée » (…-pooler…).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Connexion directe (non poolée) : utilisée par les migrations Prisma.
# Avec l'intégration Vercel + Neon, cette variable est fournie automatiquement.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Authentification Google (NextAuth / Auth.js) ---
# Identifiants OAuth créés dans la Google Cloud Console (type « Web application »).
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"

# Secret de signature des sessions NextAuth. Générer avec :  openssl rand -base64 32
NEXTAUTH_SECRET="remplacez-par-un-secret-aleatoire"

# URL de base de l'application (sans slash final).
# Local : http://localhost:5173   —   Prod : https://rdv-reunion.vercel.app
NEXTAUTH_URL="http://localhost:5173"
